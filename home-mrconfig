[DEFAULT]
include =
	cat /usr/share/mr/stow 2>/dev/null || true
	cat /usr/share/mr/download 2>/dev/null || true
	cat ~/.config/mr/mr-hooks.sh
lib = . ~/.config/mr/mr-functions.sh


# -----------------------------------------------------------------------------
# Dotfiles
# -----------------------------------------------------------------------------

[.config/mr]
order = 1
name = mr-config
chain = true
checkout = git clone -b z800 ssh://git@rpi.gnu.local/wandsas/mr-config $MR_REPO
remotes = github ssh://git@github.com/wandsas/mr-config
fixups =
	ensure_symlink_exists ~/.mrconfig ${MR_REPO}/home-mrconfig
	ensure_symlink_exists ~/.stow-global-ignore ${MR_REPO}/.stow-global-ignore

[$HOME/.GIT/wandsas/dotfiles]
order = 2
stowable = true
checkout = git clone ssh://git@rpi.gnu.local/wandsas/dotfiles
remotes = git_add_remote github ssh://git@github.com/wandsas/myrepos


[$HOME/.GIT/wandsas/myrepos]
order = 3
stowable = true
checkout = git clone ssh://git@rpi.gnu.local/wandsas/myrepos
remotes = git_add_remotes "
	github ssh://git@github.com/wandsas/myrepos
	upstream git://github.com/aspiers/kitenet-mr
	joeyh git://git.joeyh.name/myrepos"
lib = mr_init_stow_package ~/.local
fixups =
	for exe in mr mrdir mr-recache; do
	    ep=${MR_REPO}/${exe}
	    [ -x "${ep}" ] && ln -sf "$ep" ~/.local/bin
	done
	for fn in mrcd _mr _mr_repositories; do
	    fp="${MR_REPO}/zsh/$fn"
	    [ -e "${fp}" ] && ln -sf ${fp} ~/.local/share/zsh/site-functions
	done
	zsh -c zrec
skip = lazy

[$HOME/downloads/scm/stow]
order = 4
name = stow-release
lib = mr_set_download_url http://ftp.gnu.org/gnu/stow/stow-latest.tar.bz2
# lib = mr_set_download_url http://ftp.halifax.rwth-aachen.de/gnu/stow/stow-latest.tar.bz2
checkout = mr_download_checkout
fixups =
	cd $MR_REPO
	./configure --prefix=${HOME}/.local
	make install
skip = true

[$HOME/.GIT/3rd-party/stow]
order = 5
checkout = git clone git://git.savannah.gnu.org/git/stow $MR_REPO
remotes = git_add_remote rpi ssh://git@rpi.gnu.local/wandsas/stow $MR_REPO
fixups =
	cd $MR_REPO
	autoconf
	automake --add-missing
	./configure --prefix=${HOME}/.local
	make install
skip = lazy


