[DEFAULT]
include =
    if [ -e ~/.config/mr/library-loaders ]; then
        # mr-config already checked out
        . ~/.config/mr/library-loaders
        include_mr_extensions
        load_libraries ~/.config/mr/sh.d/*
        include_lib_dirs ~/.config/mr/lib.d
    fi

[.config/mr]
order = 1
name = mr-config
chain = true
checkout = git clone ssh://git@github.com/wandsas/mr-config $MR_REPO
post_checkout =
  cd $MR_REPO && git remote add ssh://git@rpi.gnu.local/mr-config
fixups =
  ln -sf "$MR_REPO/home-mrconfig" ~/.mrconfig
  ln -sf "$MR_REPO/.stow-global-ignore" ~

[$HOME/.GIT/wandsas/dotfiles]
stowable = true
checkout = git clone ssh://git@rpi.gnu.local/wandsas/dotfiles

[$HOME/.ssh]
checkout = git clone ssh://git@rpi.gnu.local/wandsas/ssh $MR_REPO
fixups = set_confidential_repo

[$HOME/.gnupg]
checkout = git clone ssh://git@rpi.gnu.local/wandsas/gnupg $MR_REPO

[$HOME/.password-store]
checkout = git clone ssh://git@rpi.gnu.local/wandsas/pass $MR_REPO

[$HOME/.GIT/3rd-party/alacritty]
stowable = true
checkout = git clone git://github.com/jwilm/alacritty
remotes = git_add_remote rpi ssh://git@rpi.gnu.local/alacritty
lib =
  mr_set_stow_target
  mr_init_stow_package
fixups =
  make clean
  cargo build --release
  install -d ${STOW_PKG_PATH}/bin
  install -d ${STOW_PKG_PATH}/share/info
  install -d ${STOW_PKG_PATH}/share/man/man1
  install -d ${STOW_PKG_PATH}/share/applications
  install -d ${STOW_PKG_PATH}/share/zsh/site-functions
  
  install -m 755 target/release/alacritty -t ${STOW_PKG_PATH}/bin/alacritty
  install -m 644 alacritty.desktop -t ${STOW_PKG_PATH}/share/applications
  install -m 644 alacritty.info -t ${STOW_PKG_PATH}/share/info
  install -m 644 alacritty.man ${STOW_PKG_PATH}/share/man/man1/alacritty.1
  install -m 644 alacritty-completions.zsh ${STOW_PKG_PATH}/share/zsh/site-functions/_alacritty
  # User configs
  [ -d "${XDG_CONFIG_HOME}/alacritty" ] || install -d ${XDG_CONFIG_HOME}/alacritty
  [ -f "${XDG_CONFIG_HOME}/alacritty.yml" ] || install -d ${XDG_CONFIG_HOME}/alacritty/alacritty.yml
  mr_restow_regardless

