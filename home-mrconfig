stowable = true
checkout = git clone --depth 1 http://llvm.org/git/clang
remotes = git_add_remote rpi ssh://git@rpi.gnu.local/wandsas/clang
fixups =
  ensure_symlink_exists ~/src/compiler/llvm/tools/clang $MR_REPO
  sed -i 's@/lib64/ld-linux-x86-64.so.2@/lib/ld-musl-x86_64.so.1@' $MR_REPO/lib/Driver/Tools.cpp
  # avoid hardcoded dependency on libgcc
