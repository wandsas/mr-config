lib = mr_init_stow_package ~/.local
fixups =
	install -d ${STOW_PKG_PATH}
	cargo build --release
	make PREFIX=${STOW_PKG_PATH} install
	mr_restow_regardless
[$HOME/.emacs.d]
order = 15
checkout = git clone git://github.com/syl20bnr/spacemacs $MR_REPO
remotes = git_add_remote rpi ssh://git@rpi.gnu.local/spacemacs

[$HOME/.cask]
order = 20
checkout = git clone git://github.com/cask/cask $MR_REPO
remotes = git_add_remote rpi ssh://git@rpi.gnu.local/cask


# -----------------------------------------------------------------------------
# Multimedia Applications
# -----------------------------------------------------------------------------

[$HOME/.GIT/3rd-party/ympd]
stowable = true
checkout = git clone git://github.com/notandy/ympd
remotes = git_add_remote rpi ssh://git@rpi.gnu.local/3rd-party/ympd
lib = mr_init_stow_package ~/.local
fixups =
	cmake -DCMAKE_INSTALL_PREFIX=${STOW_PKG_PATH}
	make install
	mr_restow_regardless


# -----------------------------------------------------------------------------
# www-clients
# -----------------------------------------------------------------------------

[$HOME/.config/tor-bundle]
checkout = git clone git://github.com/andy-portmen/tor-bundle $MR_REPO
remotes = git_add_remote rpi ssh://git@github.com/wandsas/tor-bundle
skip = lazy

